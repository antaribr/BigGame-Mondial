{
  "cleanUrls": true,
  "rewrites": [
    { "source": "/team", "destination": "/index.html" },
    { "source": "/team/:path*", "destination": "/index.html" },
    { "source": "/advisor", "destination": "/index.html" },
    { "source": "/advisor/:path*", "destination": "/index.html" },
    { "source": "/scoreboard", "destination": "/index.html" },
    { "source": "/admin", "destination": "/index.html" },
    { "source": "/admin/:path*", "destination": "/index.html" }
  ],
  "headers": [
    { "source": "/config.json", "headers": [{ "key": "Cache-Control", "value": "no-store" }] },
    { "source": "/(.*)", "headers": [{ "key": "X-Content-Type-Options", "value": "nosniff" }, { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }] }
  ]
}
